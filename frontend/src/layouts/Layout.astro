---
import '../styles/global.css';
import LoadingScreen from '../components/LoadingScreen.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { Tunnel } from '../components/thegridcn/Tunnel';
import { withBase, withAsset } from '../lib/assets.js';

const basePath = import.meta.env.BASE_URL === '/' ? '' : `/${import.meta.env.BASE_URL.replace(/^\/|\/$/g, '')}`;
const pathname = Astro.url.pathname;
const pagePath = basePath && pathname.startsWith(basePath) ? pathname.slice(basePath.length) || '/' : pathname;
const showMotionBackground = pagePath !== '/';
const siteOrigin = Astro.site?.toString() ?? Astro.url.origin;
const canonicalUrl = new URL(pathname, siteOrigin).toString();
const pageTitle = 'N8E Labs | The Next Generation of Tech is Here';
const pageDescription = "We engineer software, automation, and strategic digital systems for organizations across North East India.";
const shareImage = new URL(withAsset('/logo.png'), siteOrigin).toString();
const shareImageAlt = 'N8E Labs logo';
---

<!doctype html>
<html lang="en" data-theme="ares">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" href={withAsset('/favicon.ico')} sizes="any" />
		<link rel="icon" type="image/svg+xml" href={withAsset('/favicon.svg')} />
		<link rel="shortcut icon" href={withAsset('/favicon.ico')} />
		<link rel="apple-touch-icon" href={withAsset('/logo.png')} />
		<meta name="generator" content={Astro.generator} />
		<title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="N8E Labs" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:image" content={shareImage} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1024" />
    <meta property="og:image:height" content="1024" />
    <meta property="og:image:alt" content={shareImageAlt} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={shareImage} />
    <meta name="twitter:image:alt" content={shareImageAlt} />

		<!-- Google Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;500;700;900&family=Space+Grotesk:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <script is:inline>
      (() => {
        try {
          const savedTheme = localStorage.getItem("gridcn-theme") || "ares";
          document.documentElement.setAttribute("data-theme", savedTheme);
        } catch (error) {
          document.documentElement.setAttribute("data-theme", "ares");
        }
      })();
    </script>
	</head>
	<body class="antialiased">
		<!-- Custom Cursor -->
		<div id="custom-cursor" class="custom-cursor hidden md:block"></div>

    <LoadingScreen />

    {showMotionBackground && (
      <div class="pointer-events-none fixed inset-0 z-0 overflow-hidden">
        <Tunnel client:only="react" className="absolute inset-0 opacity-60" ringCount={12} />
        <div class="absolute inset-0 tron-grid opacity-30"></div>
        <div class="absolute inset-0 scanline-overlay opacity-20"></div>
      </div>
    )}
    
    <div class="relative z-10 flex min-h-screen flex-col">
      <Navbar />

      <main class="flex-grow pt-24"> <!-- offset sticky navbar -->
        <slot />
      </main>

      <Footer />
    </div>

		<script>
      import gsap from 'gsap';

			// Custom Cursor Logic
			const cursor = document.getElementById('custom-cursor');
			
			if (cursor && window.matchMedia("(pointer: fine)").matches) {
				cursor.classList.remove('hidden');

				window.addEventListener('mousemove', (e) => {
					gsap.to(cursor, {
						x: e.clientX,
						y: e.clientY,
						duration: 0.1,
						ease: "power2.out"
					});
				});

				// Add hover effect for links and buttons
				const addHoverListeners = () => {
					const interactiveElements = document.querySelectorAll('a, button, input, textarea, select, .interactive');
					interactiveElements.forEach(el => {
						el.addEventListener('mouseenter', () => cursor.classList.add('hover'));
						el.addEventListener('mouseleave', () => cursor.classList.remove('hover'));
					});
				};

				addHoverListeners();

				// In Astro page transitions, re-apply listeners
				document.addEventListener('astro:page-load', addHoverListeners);
			}
		</script>
	</body>
</html>
