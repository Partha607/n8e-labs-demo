---
import Layout from '../layouts/Layout.astro';
import { getServices } from '../lib/directus';

const services = await getServices();
---

<Layout>
  <section class="mx-auto max-w-6xl px-4 py-16 sm:px-6 lg:px-8">
    <div class="hud-panel p-8">
      <p class="font-mono text-[10px] uppercase tracking-[0.24em] text-primary">Service Catalog</p>
      <h1 class="mt-3 text-4xl md:text-5xl">Solutions & Services</h1>
      <p class="mt-4 max-w-3xl text-base text-muted">Grid-ready consulting and implementation services designed for modern organizations that need practical execution and measurable outcomes.</p>
    </div>
    <div class="mt-8 space-y-4">
      {services.map((service, index) => (
        <div class="hud-panel p-1">
          <details class="group marker:hidden" name="services" open={index === 0}>
            <summary class="flex cursor-none items-center justify-between p-5 font-orbitron text-xl font-bold outline-none">
              <span class="transition-colors group-hover:text-primary">{service.title}</span>
              <span class="text-primary transition group-open:rotate-180">
                <svg aria-hidden="true" fill="none" height="24" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" viewBox="0 0 24 24" width="24"><path d="M6 9l6 6 6-6"></path></svg>
              </span>
            </summary>
            <div class="whitespace-pre-line border-t px-5 pb-5 pt-4 text-sm text-muted" style="border-color: var(--border);">
              {service.description}
            </div>
          </details>
        </div>
      ))}
    </div>
  </section>
</Layout>

<style>
  details > summary {
    list-style: none; /* Hide default triangle */
  }
  details > summary::-webkit-details-marker {
    display: none;
  }
</style>

