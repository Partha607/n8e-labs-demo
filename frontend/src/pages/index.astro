---
import Layout from '../layouts/Layout.astro';
import { getPosts } from '../lib/directus';
import { Tunnel } from '../components/thegridcn/Tunnel';

const posts = await getPosts();
const latestTransmissions = posts.slice(0, 3);
const withBase = (path) => `${import.meta.env.BASE_URL}${path.replace(/^\//, '')}`;
---

<Layout>
  <section class="relative overflow-hidden px-4 pb-20 pt-12 sm:px-6 lg:px-8">
    <Tunnel client:only="react" className="pointer-events-none absolute inset-0 opacity-70" />
    <div class="pointer-events-none absolute inset-0 tron-grid"></div>
    <div class="pointer-events-none absolute inset-0 scanline-overlay opacity-35"></div>
    <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_50%_42%,color-mix(in_srgb,var(--primary)_24%,transparent)_0%,transparent_60%)]"></div>
    <div class="relative mx-auto max-w-7xl">
      <div class="mx-auto max-w-4xl rounded-2xl border border-primary/20 bg-[color:var(--surface)]/40 p-8 text-center backdrop-blur-sm md:p-12">
        <p class="font-mono text-[10px] uppercase tracking-[0.24em] text-primary">System Status: Operational</p>
        <h1 class="mt-4 text-4xl font-black leading-tight md:text-6xl">The Next Generation Of Tech Is Here</h1>
        <p class="mx-auto mt-5 max-w-3xl text-base text-muted md:text-lg">
          We engineer software, automation, and strategic digital systems for organizations across North East India. Our goal is to develop and empower young boys and girls of North East India.
        </p>
        <div class="mt-8 flex flex-wrap justify-center gap-3">
          <a href={withBase('/contact')} class="btn-grid interactive">Enter The Lab</a>
          <a href={withBase('/services')} class="interactive rounded-sm border px-4 py-2 font-mono text-[11px] uppercase tracking-[0.16em] text-muted transition-colors hover:text-primary" style="border-color: var(--border);">
            Explore Services
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-7xl">
      <div class="mb-8">
        <p class="font-mono text-[10px] uppercase tracking-[0.24em] text-primary">Capabilities</p>
        <h2 class="mt-2 text-3xl md:text-4xl">Core Pillars</h2>
      </div>
      <div class="grid gap-4 md:grid-cols-3">
        <article class="hud-panel p-6">
          <p class="mb-3 font-mono text-[10px] uppercase tracking-[0.2em] text-primary">01</p>
          <h3 class="text-xl">Tech Creation</h3>
          <p class="mt-3 text-sm text-muted">Next-generation products built with modern architecture, robust integration patterns, and long-term maintainability.</p>
        </article>
        <article class="hud-panel p-6">
          <p class="mb-3 font-mono text-[10px] uppercase tracking-[0.2em] text-primary">02</p>
          <h3 class="text-xl">Implementation</h3>
          <p class="mt-3 text-sm text-muted">Structured rollout for automation, data workflows, and cloud modernization with practical business outcomes.</p>
        </article>
        <article class="hud-panel p-6">
          <p class="mb-3 font-mono text-[10px] uppercase tracking-[0.2em] text-primary">03</p>
          <h3 class="text-xl">Business Integration</h3>
          <p class="mt-3 text-sm text-muted">Technology adoption with measurable ROI, operational reliability, and region-first execution strategy.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-7xl">
      <div class="mb-8 flex items-center justify-between">
        <div>
          <p class="font-mono text-[10px] uppercase tracking-[0.24em] text-primary">Blog Feed</p>
          <h2 class="mt-2 text-3xl md:text-4xl">Latest Transmissions</h2>
        </div>
        <a href={withBase('/blog')} class="interactive font-mono text-[10px] uppercase tracking-[0.2em] text-muted transition-colors hover:text-primary">View All</a>
      </div>
      <div class="grid gap-4 md:grid-cols-3">
        {latestTransmissions.map((post) => (
          <a href={withBase(`/blog/${post.slug}`)} class="interactive hud-panel block p-5 transition-transform hover:-translate-y-1">
            <p class="font-mono text-[10px] uppercase tracking-[0.2em] text-primary">Transmission</p>
            <h3 class="mt-2 text-lg leading-snug">{post.title}</h3>
            <p class="mt-3 line-clamp-3 text-sm text-muted">{post.content}</p>
            <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.16em] text-muted">{post.date_published}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <script is:inline src={withBase('/mapdata.js')}></script>
  <script is:inline src={withBase('/countrymap.js')}></script>
</Layout>
