---
const withBase = (path = '') => `${import.meta.env.BASE_URL.replace(/\/?$/, '/')}${path.replace(/^\//, '')}`;
---

<footer class="mt-20 border-t" style="border-color: var(--border); background: var(--surface);">
  <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <div class="grid gap-6 md:grid-cols-4">
      <div class="hud-panel p-5 md:col-span-2">
        <div class="mb-3">
          <img
            src={withBase('/logo.png')}
            alt="N8E Labs"
            class="h-16 w-16 object-contain sm:h-20 sm:w-20"
            loading="lazy"
            decoding="async"
          />
        </div>
        <p class="max-w-xl text-sm text-muted">
          Building North East India's next-generation technology systems, scalable delivery, and measurable outcomes.
        </p>
      </div>
      <div class="hud-panel p-5">
        <p class="mb-3 font-mono text-[10px] uppercase tracking-[0.24em] text-muted">Navigation</p>
        <ul class="space-y-2 text-sm">
          <li><a href={withBase('/about')} class="interactive text-muted transition-colors hover:text-primary">About</a></li>
          <li><a href={withBase('/services')} class="interactive text-muted transition-colors hover:text-primary">Services</a></li>
          <li><a href={withBase('/blog')} class="interactive text-muted transition-colors hover:text-primary">Blog</a></li>
          <li><a href={withBase('/contact')} class="interactive text-muted transition-colors hover:text-primary">Contact</a></li>
        </ul>
      </div>
      <div class="hud-panel p-5">
        <p class="mb-3 font-mono text-[10px] uppercase tracking-[0.24em] text-muted">Coordinates</p>
        <ul class="space-y-2 text-sm text-muted">
          <li>Guwahati, Assam</li>
          <li>North East India</li>
          <li>
            <a href="mailto:hello@n8elabs.com" class="interactive text-primary transition-colors hover:text-[color:var(--foreground)]">
              hello@n8elabs.com
            </a>
          </li>
        </ul>
      </div>
    </div>
    <div class="mt-8 flex flex-col gap-2 border-t pt-4 text-xs text-muted md:flex-row md:items-center md:justify-between" style="border-color: var(--border);">
      <p>&copy; {new Date().getFullYear()} N8E Labs. All rights reserved.</p>
      <div class="flex gap-4">
        <a href="#" class="interactive transition-colors hover:text-primary">Terms</a>
        <a href="#" class="interactive transition-colors hover:text-primary">Privacy</a>
      </div>
    </div>
  </div>
</footer>
