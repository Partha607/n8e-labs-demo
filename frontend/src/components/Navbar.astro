---
import ThemeSwitcher from './ThemeSwitcher.astro';

const withBase = (path = '') => `${import.meta.env.BASE_URL.replace(/\/?$/, '/')}${path.replace(/^\//, '')}`;
---

<nav id="main-nav" class="fixed left-0 right-0 top-0 z-50 border-b bg-[color:var(--surface)]/90 backdrop-blur-md transition-transform duration-300 ease-in-out" style="border-color: var(--border);">
  <div class="mx-auto max-w-7xl px-4 py-3 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between gap-4">
      <a href={withBase('/')} class="interactive group shrink-0">
        <img
          src={withBase('/logo.png')}
          alt="N8E Labs"
          class="h-12 w-12 object-contain transition-opacity group-hover:opacity-90 sm:h-14 sm:w-14"
          loading="eager"
          decoding="async"
        />
      </a>

      <div class="hidden items-center gap-5 lg:flex">
        <a href={withBase('/')} class="interactive text-xs uppercase tracking-[0.16em] text-muted transition-colors hover:text-primary">Home</a>
        <a href={withBase('/about')} class="interactive text-xs uppercase tracking-[0.16em] text-muted transition-colors hover:text-primary">About</a>
        <a href={withBase('/services')} class="interactive text-xs uppercase tracking-[0.16em] text-muted transition-colors hover:text-primary">Services</a>
        <a href={withBase('/blog')} class="interactive text-xs uppercase tracking-[0.16em] text-muted transition-colors hover:text-primary">Blog</a>
        <a href={withBase('/contact')} class="interactive text-xs uppercase tracking-[0.16em] text-muted transition-colors hover:text-primary">Contact</a>
      </div>

      <div class="hidden items-center gap-2 lg:flex">
        <ThemeSwitcher />
        <a href={withBase('/contact')} class="btn-grid interactive">Enter Grid</a>
      </div>

      <button id="mobile-nav-toggle" class="interactive rounded-sm border px-2 py-1 text-xs uppercase tracking-[0.14em] text-primary lg:hidden" style="border-color: var(--border);" type="button">
        Menu
      </button>
    </div>
    <div id="mobile-nav-panel" class="mt-3 hidden lg:hidden">
      <div class="hud-panel p-3">
        <div class="mb-3 grid grid-cols-2 gap-2">
          <a href={withBase('/')} class="interactive text-[11px] uppercase tracking-[0.16em] text-muted">Home</a>
          <a href={withBase('/about')} class="interactive text-[11px] uppercase tracking-[0.16em] text-muted">About</a>
          <a href={withBase('/services')} class="interactive text-[11px] uppercase tracking-[0.16em] text-muted">Services</a>
          <a href={withBase('/blog')} class="interactive text-[11px] uppercase tracking-[0.16em] text-muted">Blog</a>
          <a href={withBase('/contact')} class="interactive text-[11px] uppercase tracking-[0.16em] text-muted">Contact</a>
        </div>
        <ThemeSwitcher />
      </div>
    </div>
  </div>
</nav>

<script>
  const setupMobileNav = () => {
    const button = document.getElementById("mobile-nav-toggle");
    const panel = document.getElementById("mobile-nav-panel");
    if (!button || !panel) return;
    button.addEventListener("click", () => {
      panel.classList.toggle("hidden");
    });
  };

  const setupNavScroll = () => {
    const nav = document.getElementById("main-nav");
    if (!nav) return;

    let lastScrollY = window.scrollY;
    let hidden = false;

    const update = () => {
      const currentScrollY = window.scrollY;
      const mobilePanel = document.getElementById("mobile-nav-panel");
      const mobileOpen = mobilePanel && !mobilePanel.classList.contains("hidden");

      if (mobileOpen || currentScrollY <= 0) {
        if (hidden) {
          nav.classList.remove("-translate-y-full");
          hidden = false;
        }
      } else if (currentScrollY > lastScrollY && currentScrollY > 72) {
        if (!hidden) {
          nav.classList.add("-translate-y-full");
          hidden = true;
        }
      } else if (currentScrollY < lastScrollY) {
        if (hidden) {
          nav.classList.remove("-translate-y-full");
          hidden = false;
        }
      }

      lastScrollY = currentScrollY;
    };

    let ticking = false;
    window.addEventListener(
      "scroll",
      () => {
        if (!ticking) {
          window.requestAnimationFrame(() => {
            update();
            ticking = false;
          });
          ticking = true;
        }
      },
      { passive: true }
    );
  };

  document.addEventListener("astro:page-load", () => {
    setupMobileNav();
    setupNavScroll();
  });
  setupMobileNav();
  setupNavScroll();
</script>
