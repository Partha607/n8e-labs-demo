---
const themes = [
  { id: "tron", label: "Tron" },
  { id: "ares", label: "Ares" },
  { id: "clu", label: "Clu" },
  { id: "athena", label: "Athena" },
  { id: "aphrodite", label: "Aphrodite" },
  { id: "poseidon", label: "Poseidon" },
];
---

<details class="group relative">
  <summary class="interactive list-none rounded-sm border px-3 py-2 font-mono text-[10px] uppercase tracking-[0.16em] text-muted transition-colors hover:text-primary" style="border-color: var(--border);">
    Choose your theme
  </summary>
  <div class="absolute right-0 z-50 mt-2 w-56 hud-panel p-2">
    <div class="grid grid-cols-2 gap-1.5">
      {
        themes.map((theme) => (
          <button
            type="button"
            data-theme-option={theme.id}
            class="theme-option w-full rounded-sm border px-2 py-1 text-center font-mono text-[10px] uppercase tracking-[0.16em] transition-colors"
          >
            {theme.label}
          </button>
        ))
      }
    </div>
  </div>
</details>

<script>
  const THEME_KEY = "gridcn-theme";

  const applyTheme = (theme) => {
    document.documentElement.setAttribute("data-theme", theme);
    const options = document.querySelectorAll(".theme-option");
    options.forEach((button) => {
      const target = button.getAttribute("data-theme-option");
      const active = target === theme;
      button.classList.toggle("border-primary", active);
      button.classList.toggle("text-primary", active);
      button.classList.toggle("neon-box-shadow", active);
      if (!active) {
        button.classList.remove("neon-box-shadow");
      }
    });
  };

  const initThemeSwitcher = () => {
    const saved = localStorage.getItem(THEME_KEY) || "ares";
    applyTheme(saved);
    document.querySelectorAll(".theme-option").forEach((button) => {
      button.addEventListener("click", () => {
        const theme = button.getAttribute("data-theme-option");
        if (!theme) return;
        localStorage.setItem(THEME_KEY, theme);
        applyTheme(theme);
        const dropdown = button.closest("details");
        if (dropdown) dropdown.removeAttribute("open");
      });
    });
  };

  document.addEventListener("astro:page-load", initThemeSwitcher);
  initThemeSwitcher();
</script>
